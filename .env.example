# Copy to .env and fill in real values. Never commit the real .env file.

APP_NAME=Agent Guardrail Engine
ENV=development
DEBUG=false

# --- Database ---
DATABASE_URL=postgresql+asyncpg://guardrail:guardrail@db:5432/guardrail
SYNC_DATABASE_URL=postgresql+psycopg2://guardrail:guardrail@db:5432/guardrail
POSTGRES_USER=guardrail
POSTGRES_PASSWORD=guardrail
POSTGRES_DB=guardrail

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Policy engine ---
POLICY_DEFAULT_EFFECT=deny
POLICY_ENGINE_BACKEND=internal
OPA_URL=

# --- Seed script (dev only) ---
SEED_ADMIN_EMAIL=admin@guardrail.example.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
